---
import type { PortfolioContent } from '../data/types';
import SocialLinks from './SocialLinks.astro';
import ToptalBadge from './ToptalBadge.astro';

interface Props {
  content: PortfolioContent;
}

const { content } = Astro.props;
const { copy, site } = content;
const hero = copy.hero;
---

<section id="hero" class="relative overflow-hidden pt-32 pb-20 sm:pt-40 sm:pb-28">
  <!-- Decorative animated background blobs -->
  <div class="pointer-events-none absolute inset-0 -z-10" aria-hidden="true">
    <div
      class="absolute -top-24 right-[10%] h-72 w-72 rounded-full bg-accent-600/20 blur-3xl animate-pulse-slow"
    >
    </div>
    <div
      class="absolute top-40 left-[5%] h-64 w-64 rounded-full bg-accent-400/10 blur-3xl animate-float"
    >
    </div>
    <div
      class="absolute inset-0 bg-[linear-gradient(to_right,rgba(148,163,184,0.04)_1px,transparent_1px),linear-gradient(to_bottom,rgba(148,163,184,0.04)_1px,transparent_1px)] bg-[size:3rem_3rem] [mask-image:radial-gradient(ellipse_70%_60%_at_50%_0%,#000_60%,transparent_100%)]"
    >
    </div>
  </div>

  <div class="container-content">
    <div class="flex flex-col gap-12 lg:flex-row lg:items-start lg:justify-between">
    <div class="max-w-3xl">
      <p class="reveal mb-4 inline-flex items-center gap-2 rounded-full border border-surface-border bg-surface/60 px-4 py-1.5 text-sm text-ink-muted">
        <span class="relative flex h-2 w-2">
          <span class="absolute inline-flex h-full w-full animate-ping rounded-full bg-green-400 opacity-75"></span>
          <span class="relative inline-flex h-2 w-2 rounded-full bg-green-400"></span>
        </span>
        {site.location}
      </p>

      <h1 class="reveal text-4xl font-extrabold tracking-tight text-ink-strong sm:text-6xl" style="--reveal-delay: 60ms">
        <span class="block text-lg font-medium text-ink-muted sm:text-xl">{hero.greeting}</span>
        <span class="text-gradient">{site.name}</span>
      </h1>

      <p class="reveal mt-4 text-xl font-semibold text-accent-fg sm:text-2xl" style="--reveal-delay: 120ms">
        {hero.role}
      </p>

      <p class="reveal mt-5 max-w-2xl text-lg text-ink-muted" style="--reveal-delay: 180ms">
        {hero.tagline}
      </p>

      <div class="reveal mt-8 flex flex-wrap items-center gap-3" style="--reveal-delay: 240ms">
        <a href="#projects" class="btn btn-primary">{hero.ctaProjects}</a>
        <a href="#contact" class="btn btn-secondary">{hero.ctaContact}</a>
        <a href={site.cvPath} download class="btn btn-secondary">
          <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M12 3v12m0 0 4-4m-4 4-4-4M4 17v2a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2v-2" />
          </svg>
          {hero.ctaCv}
        </a>
      </div>

      <div class="reveal mt-8" style="--reveal-delay: 300ms">
        <SocialLinks links={site.socials} />
      </div>
    </div>

      <ToptalBadge class="reveal mx-auto shrink-0 lg:mx-0 lg:mt-2" />
    </div>

    <!-- Stats -->
    <dl class="reveal mt-16 grid grid-cols-2 gap-4 sm:grid-cols-4" style="--reveal-delay: 360ms">
      {
        hero.stats.map((stat) => (
          <div class="card p-5">
            <dt class="text-3xl font-bold text-ink-strong">{stat.value}</dt>
            <dd class="mt-1 text-sm text-ink-muted">{stat.label}</dd>
          </div>
        ))
      }
    </dl>
  </div>
</section>
