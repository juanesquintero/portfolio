---
import type { PortfolioContent } from '../data/types';
import SectionHeading from './SectionHeading.astro';

interface Props {
  content: PortfolioContent;
}

const { content } = Astro.props;
const { projects } = content;
const copy = content.copy.projects;
---

<section id="projects" class="section bg-bg-soft/40">
  <div class="container-content">
    <SectionHeading eyebrow={copy.eyebrow} heading={copy.heading} intro={copy.intro} />

    <div class="grid gap-5 sm:grid-cols-2 lg:grid-cols-3">
      {
        projects.map((project, i) => (
          <article class="card card-hover reveal flex flex-col p-6" style={`--reveal-delay: ${(i % 3) * 60}ms`}>
            <div class="mb-3 flex flex-wrap gap-2">
              {project.industries.map((tag) => (
                <span class="chip chip-accent">{tag}</span>
              ))}
            </div>

            <h3 class="text-lg font-semibold text-ink-strong">{project.title}</h3>
            <p class="mt-1 text-xs font-medium uppercase tracking-wider text-ink-faint">{project.company}</p>
            <p class="mt-3 text-sm leading-relaxed text-ink-muted">{project.blurb}</p>

            <ul class="mt-4 space-y-2">
              {project.highlights.map((h) => (
                <li class="flex gap-2.5 text-sm text-ink-muted">
                  <svg class="mt-1 h-3.5 w-3.5 flex-none text-accent-fg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
                    <path stroke-linecap="round" stroke-linejoin="round" d="m5 12 5 5L20 7" />
                  </svg>
                  <span>{h}</span>
                </li>
              ))}
            </ul>

            <ul class="mt-5 flex flex-wrap gap-2 border-t border-surface-border pt-4">
              {project.tech.map((t) => (
                <li class="chip">{t}</li>
              ))}
            </ul>
          </article>
        ))
      }
    </div>
  </div>
</section>
