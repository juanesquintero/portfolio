---
import type { PortfolioContent } from '../data/types';
import SectionHeading from './SectionHeading.astro';

interface Props {
  content: PortfolioContent;
}

const { content } = Astro.props;
const { experience } = content;
const copy = content.copy.experience;
---

<section id="experience" class="section">
  <div class="container-content">
    <SectionHeading eyebrow={copy.eyebrow} heading={copy.heading} />

    <ol class="relative space-y-8 border-l border-surface-border pl-6 sm:pl-8">
      {
        experience.map((role, i) => (
          <li class="reveal relative" style={`--reveal-delay: ${Math.min(i, 4) * 60}ms`}>
            <span class="absolute -left-[1.6rem] top-1.5 flex h-3.5 w-3.5 items-center justify-center sm:-left-[2.1rem]">
              <span class="h-3.5 w-3.5 rounded-full border-2 border-accent-400 bg-bg ring-4 ring-bg" />
            </span>

            <div class="card card-hover p-6">
              <div class="flex flex-col gap-1 sm:flex-row sm:items-center sm:justify-between">
                <h3 class="text-lg font-semibold text-ink-strong">
                  {role.title} ·{' '}
                  {role.url ? (
                    <a href={role.url} target="_blank" rel="noopener noreferrer" class="text-accent-fg hover:text-accent-fg">
                      {role.company}
                    </a>
                  ) : (
                    <span class="text-accent-fg">{role.company}</span>
                  )}
                </h3>
                <span class="chip chip-accent shrink-0">{role.period}</span>
              </div>

              <p class="mt-1 text-sm text-ink-faint">{role.location}</p>
              <p class="mt-3 text-sm leading-relaxed text-ink-muted">{role.summary}</p>

              <ul class="mt-4 space-y-2">
                {role.highlights.map((h) => (
                  <li class="flex gap-2.5 text-sm text-ink-muted">
                    <svg class="mt-1 h-3.5 w-3.5 flex-none text-accent-fg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
                      <path stroke-linecap="round" stroke-linejoin="round" d="m5 13 4 4L19 7" />
                    </svg>
                    <span>{h}</span>
                  </li>
                ))}
              </ul>

              <ul class="mt-4 flex flex-wrap gap-2">
                {role.tech.map((t) => (
                  <li class="chip">{t}</li>
                ))}
              </ul>
            </div>
          </li>
        ))
      }
    </ol>
  </div>
</section>
