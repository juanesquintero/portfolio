---
import type { PortfolioContent } from '../data/types';
import SectionHeading from './SectionHeading.astro';

interface Props {
  content: PortfolioContent;
}

const { content } = Astro.props;
const techStack = content.copy.techStack;
const { techStack: items } = content.site;
---

<section id="tech-stack" class="section">
  <div class="container-content">
    <SectionHeading eyebrow={techStack.eyebrow} heading={techStack.heading} intro={techStack.intro} />

    <ul
      class="grid grid-cols-3 gap-3 sm:grid-cols-4 sm:gap-4 md:grid-cols-5 lg:grid-cols-6 xl:grid-cols-7"
      role="list"
    >
      {
        items.map((tech, i) => (
          <li class="reveal" style={`--reveal-delay: ${Math.min(i, 12) * 40}ms`}>
            <div
              class="group flex h-full flex-col items-center justify-center gap-3 rounded-xl bg-white/[0.05] p-4 ring-1 ring-white/10 transition-all duration-300 hover:-translate-y-1 hover:bg-white/[0.08] hover:ring-accent-500/40"
              title={tech.name}
            >
              <img
                src={`/tech/${tech.slug}.svg`}
                alt={`${tech.name} logo`}
                width="40"
                height="40"
                loading="lazy"
                decoding="async"
                class="h-10 w-10 transition-transform duration-300 group-hover:scale-110"
              />
              <span class="text-center text-xs font-medium text-ink-muted transition-colors group-hover:text-white sm:text-sm">
                {tech.name}
              </span>
            </div>
          </li>
        ))
      }
    </ul>
  </div>
</section>
