---
import type { SocialLink } from '../data/types';

interface Props {
  links: SocialLink[];
  class?: string;
}

const { links, class: className = '' } = Astro.props;

// Inline SVG paths keyed by the icon name in site.ts
const icons: Record<SocialLink['icon'], string> = {
  email:
    'M1.5 8.67v8.58a3 3 0 0 0 3 3h15a3 3 0 0 0 3-3V8.67l-8.928 5.493a3 3 0 0 1-3.144 0L1.5 8.67Z M22.5 6.908V6.75a3 3 0 0 0-3-3h-15a3 3 0 0 0-3 3v.158l9.714 5.978a1.5 1.5 0 0 0 1.572 0L22.5 6.908Z',
  linkedin:
    'M20.45 20.45h-3.56v-5.57c0-1.33-.02-3.04-1.85-3.04-1.85 0-2.14 1.45-2.14 2.94v5.67H9.34V9h3.42v1.56h.05c.48-.9 1.64-1.85 3.37-1.85 3.6 0 4.27 2.37 4.27 5.46v6.28ZM5.34 7.43a2.06 2.06 0 1 1 0-4.13 2.06 2.06 0 0 1 0 4.13ZM7.12 20.45H3.56V9h3.56v11.45ZM22.22 0H1.77C.79 0 0 .77 0 1.73v20.54C0 23.22.79 24 1.77 24h20.45c.98 0 1.78-.78 1.78-1.73V1.73C24 .77 23.2 0 22.22 0Z',
  github:
    'M12 .5C5.37.5 0 5.87 0 12.5c0 5.3 3.44 9.8 8.21 11.39.6.11.82-.26.82-.58v-2.02c-3.34.73-4.04-1.61-4.04-1.61-.55-1.39-1.34-1.76-1.34-1.76-1.09-.75.08-.73.08-.73 1.2.09 1.84 1.24 1.84 1.24 1.07 1.83 2.81 1.3 3.5.99.11-.78.42-1.3.76-1.6-2.67-.3-5.47-1.34-5.47-5.96 0-1.32.47-2.39 1.24-3.23-.12-.31-.54-1.53.12-3.19 0 0 1.01-.32 3.3 1.23a11.5 11.5 0 0 1 6.01 0c2.29-1.55 3.3-1.23 3.3-1.23.66 1.66.24 2.88.12 3.19.77.84 1.24 1.91 1.24 3.23 0 4.63-2.81 5.65-5.49 5.95.43.37.81 1.1.81 2.22v3.29c0 .32.21.7.83.58A12 12 0 0 0 24 12.5C24 5.87 18.63.5 12 .5Z',
  gitlab:
    'M23.55 9.6 23.52 9.5 20.3.97a.84.84 0 0 0-.83-.57.84.84 0 0 0-.8.58l-2.18 6.67H7.5L5.32.98a.84.84 0 0 0-.8-.58.85.85 0 0 0-.8.58L.48 9.5l-.03.1a5.98 5.98 0 0 0 1.98 6.9l.01.01.03.02 4.9 3.67 2.43 1.84 1.48 1.12a.99.99 0 0 0 1.2 0l1.48-1.12 2.43-1.84 4.93-3.69.01-.01a6 6 0 0 0 1.98-6.9Z',
};
---

<ul class={`flex items-center gap-3 ${className}`}>
  {
    links.map((link) => (
      <li>
        <a
          href={link.url}
          aria-label={link.label}
          title={link.label}
          target={link.icon === 'email' ? undefined : '_blank'}
          rel={link.icon === 'email' ? undefined : 'noopener noreferrer'}
          class="flex h-10 w-10 items-center justify-center rounded-xl border border-surface-border bg-surface/60 text-ink-muted transition-all hover:-translate-y-0.5 hover:border-accent-500/50 hover:text-accent-fg"
        >
          <svg viewBox="0 0 24 24" class="h-5 w-5" fill="currentColor" aria-hidden="true">
            <path d={icons[link.icon]} />
          </svg>
        </a>
      </li>
    ))
  }
</ul>
