---
import '@fontsource-variable/inter';
import '../styles/global.css';
import { site } from '../data/site';
import type { Locale } from '../data/types';

interface Props {
  lang: Locale;
  title: string;
  description: string;
}

const { lang, title, description } = Astro.props;

const canonical = new URL(Astro.url.pathname, Astro.site).href;
const ogImage = new URL('/og-image.svg', Astro.site).href;
const ogLocale = lang === 'es' ? 'es_CO' : 'en_US';

// hreflang alternates: '/' (en) and '/es/' (es)
const alternates = [
  { hreflang: 'en', href: new URL('/', Astro.site).href },
  { hreflang: 'es', href: new URL('/es/', Astro.site).href },
  { hreflang: 'x-default', href: new URL('/', Astro.site).href },
];

const personSchema = {
  '@context': 'https://schema.org',
  '@type': 'Person',
  name: site.name,
  jobTitle: 'Senior Full-Stack Software Engineer',
  email: `mailto:${site.email}`,
  address: { '@type': 'PostalAddress', addressLocality: 'Medellín', addressCountry: 'CO' },
  url: Astro.site?.href,
  sameAs: site.socials.filter((s) => s.icon !== 'email').map((s) => s.url),
  knowsLanguage: ['Spanish', 'English'],
};
---

<!doctype html>
<html lang={lang} class="dark scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="theme-color" content="#0a0f1c" />

    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="author" content={site.name} />
    <link rel="canonical" href={canonical} />
    {alternates.map((a) => <link rel="alternate" hreflang={a.hreflang} href={a.href} />)}

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content={site.name} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:locale" content={ogLocale} />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    <link rel="sitemap" href="/sitemap-index.xml" />
    <script type="application/ld+json" set:html={JSON.stringify(personSchema)} is:inline />
  </head>
  <body>
    <a
      href="#main"
      class="sr-only focus:not-sr-only focus:fixed focus:left-4 focus:top-4 focus:z-[100] focus:rounded-lg focus:bg-accent-500 focus:px-4 focus:py-2 focus:text-sm focus:font-semibold focus:text-white"
    >
      Skip to content
    </a>
    <slot />

    <script>
      // Reveal-on-scroll: progressively enhance sections with a fade-in.
      const reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
      const items = document.querySelectorAll('.reveal');
      if (reduce || !('IntersectionObserver' in window)) {
        items.forEach((el) => el.classList.add('is-visible'));
      } else {
        const io = new IntersectionObserver(
          (entries, obs) => {
            entries.forEach((entry) => {
              if (entry.isIntersecting) {
                entry.target.classList.add('is-visible');
                obs.unobserve(entry.target);
              }
            });
          },
          { rootMargin: '0px 0px -10% 0px', threshold: 0.1 }
        );
        items.forEach((el) => io.observe(el));
      }
    </script>
  </body>
</html>
